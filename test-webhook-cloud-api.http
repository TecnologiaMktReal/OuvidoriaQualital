### Teste com Imagem (Simulação)
POST https://h.coopedu.com.br/api/webhooks/whatsapp
Content-Type: application/json

{
  "object": "whatsapp_business_account",
  "entry": [
    {
      "id": "BUSINESS_ACCOUNT_ID",
      "changes": [
        {
          "value": {
            "messaging_product": "whatsapp",
            "metadata": {
              "display_phone_number": "5511999999999",
              "phone_number_id": "123456789012345"
            },
            "contacts": [
              {
                "profile": {
                  "name": "Usuario Teste"
                },
                "wa_id": "5511988888888"
              }
            ],
            "messages": [
              {
                "from": "5511988888888",
                "id": "wamid.image_test_001",
                "timestamp": "1737395100",
                "type": "image",
                "image": {
                  "id": "MEDIA_ID_FAKE_12345",
                  "mime_type": "image/jpeg",
                  "sha256": "fake_hash",
                  "caption": "Foto enviada via WhatsApp"
                }
              }
            ]
          },
          "field": "messages"
        }
      ]
    }
  ]
}

